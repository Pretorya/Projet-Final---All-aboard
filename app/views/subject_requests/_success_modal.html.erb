<div id="request-subject-modal" data-modal-container class="fixed inset-0 z-[60]">
  <button type="button" class="absolute inset-0 bg-black/80 backdrop-blur-sm w-full h-full cursor-default" data-action="modal#close"></button>
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div class="glass w-full max-w-sm rounded-2xl p-8 text-center animate-slide-up">
      <div class="w-16 h-16 rounded-full bg-green-500/20 flex items-center justify-center mx-auto mb-4">
        <i class="fas fa-check text-green-400 text-2xl"></i>
      </div>
      <h3 class="text-xl font-bold mb-2">Demande envoyée !</h3>
      <p class="text-gray-400 text-sm mb-6">Merci pour votre suggestion. Notre équipe l'examinera dans les plus brefs délais.</p>
      <button type="button" data-action="modal#close" class="w-full py-3 rounded-xl bg-primary hover:bg-primary/80 text-white font-medium transition-colors">
        Fermer
      </button>
    </div>
  </div>
</div>
