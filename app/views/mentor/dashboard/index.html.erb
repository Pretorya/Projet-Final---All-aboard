<% content_for :title, "Espace Mentor" %>

<div class="max-w-4xl mx-auto py-8 px-4">
  <div class="mb-8">
    <h1 class="text-3xl font-bold mb-1">
      <i class="fas fa-chalkboard-teacher text-emerald-400 mr-3"></i>Mon espace Mentor
    </h1>
    <p class="text-gray-400">Validez les ressources soumises par la communauté dans vos domaines de compétence.</p>
  </div>

  <%# Statistiques %>
  <div class="grid grid-cols-3 gap-4 mb-8">
    <div class="glass rounded-2xl p-6 text-center">
      <p class="text-3xl font-bold text-emerald-400"><%= @resources.count %></p>
      <p class="text-xs text-gray-400 mt-1">Ressource<%= @resources.count != 1 ? "s" : "" %> publiée<%= @resources.count != 1 ? "s" : "" %></p>
    </div>
    <div class="glass rounded-2xl p-6 text-center <%= @pending_resources.any? ? 'ring-1 ring-yellow-400/40' : '' %>">
      <p class="text-3xl font-bold <%= @pending_resources.any? ? 'text-yellow-400' : 'text-gray-500' %>"><%= @pending_resources.count %></p>
      <p class="text-xs text-gray-400 mt-1">Ressources à valider</p>
      <% if @pending_resources.any? %>
        <p class="text-xs text-yellow-400 mt-1"><i class="fas fa-circle-exclamation mr-1"></i>Action requise</p>
      <% end %>
    </div>
    <div class="glass rounded-2xl p-6 text-center <%= @help_posts.any? ? 'ring-1 ring-red-400/40' : '' %>">
      <p class="text-3xl font-bold <%= @help_posts.any? ? 'text-red-400' : 'text-gray-500' %>"><%= @help_posts.count %></p>
      <p class="text-xs text-gray-400 mt-1">Demandes d'aide</p>
      <% if @help_posts.any? %>
        <p class="text-xs text-red-400 mt-1"><i class="fas fa-circle-exclamation mr-1"></i>Action requise</p>
      <% end %>
    </div>
  </div>

  <%# Panel demandes d'aide HelpMentor %>
  <% if current_user.competences.any? %>
    <div class="glass rounded-2xl mb-6">
      <div class="p-5 border-b border-white/10 flex items-center gap-2">
        <i class="fas fa-hand-holding-heart text-red-400"></i>
        <h2 class="font-semibold">Demandes d'aide</h2>
        <% if @help_posts.any? %>
          <span class="px-2 py-0.5 rounded-full text-xs bg-red-400/15 text-red-400 font-medium"><%= @help_posts.count %></span>
        <% end %>
      </div>

      <% if @help_posts.any? %>
        <div class="divide-y divide-white/5">
          <% @help_posts.each do |post| %>
            <div class="p-5 flex items-start gap-4">
              <img src="<%= post.user.profile_avatar %>" class="w-9 h-9 rounded-full flex-shrink-0 mt-0.5">
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-1">
                  <span class="font-semibold text-sm"><%= post.user.display_name %></span>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium border"
                        style="color:<%= post.subject.accent_color %>;border-color:<%= post.subject.accent_color %>33;background-color:<%= post.subject.accent_color %>18;">
                    <i class="fas <%= post.subject.icon %> text-[10px]"></i>
                    <%= post.subject.name %>
                  </span>
                  <span class="text-xs text-gray-500 ml-auto"><%= time_ago_in_words(post.created_at) %></span>
                </div>
                <p class="text-sm font-medium text-white mb-1"><%= post.title %></p>
                <p class="text-sm text-gray-400 line-clamp-2"><%= post.body.truncate(150) %></p>
              </div>
              <%= link_to post_path(post), class: "flex-shrink-0 flex items-center gap-1.5 px-3 py-1.5 bg-red-400/10 hover:bg-red-400/20 text-red-400 rounded-xl text-sm font-medium transition-colors", data: { turbo_frame: "_top" } do %>
                <i class="fas fa-arrow-right text-xs"></i> Aider
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="p-8 text-center text-gray-500">
          <i class="fas fa-hand-holding-heart text-3xl mb-3 block text-gray-600"></i>
          <p class="text-sm">Aucune demande d'aide pour le moment.</p>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Panel de validation %>
  <div class="glass rounded-2xl">
    <div class="p-5 border-b border-white/10 flex items-center justify-between">
      <h2 class="font-semibold flex items-center gap-2">
        <i class="fas fa-clipboard-check text-yellow-400"></i>
        Ressources à valider
        <% if @pending_resources.any? %>
          <span class="px-2 py-0.5 rounded-full text-xs bg-yellow-400/15 text-yellow-400 font-medium"><%= @pending_resources.count %></span>
        <% end %>
      </h2>
      <% if current_user.competences.empty? %>
        <%= link_to edit_user_registration_path, class: "text-xs text-gray-400 hover:text-white transition-colors flex items-center gap-1" do %>
          <i class="fas fa-cog"></i> Configurer mes compétences
        <% end %>
      <% end %>
    </div>

    <% if current_user.competences.empty? %>
      <div class="p-10 text-center text-gray-400">
        <i class="fas fa-tag text-3xl mb-4 block text-gray-600"></i>
        <p class="font-medium mb-2">Aucune compétence sélectionnée</p>
        <p class="text-sm mb-4">Ajoute des compétences sur ton profil pour recevoir les ressources correspondantes.</p>
        <%= link_to edit_user_registration_path, class: "inline-block px-4 py-2 bg-emerald-500/20 text-emerald-400 rounded-xl text-sm font-medium hover:bg-emerald-500/30 transition-colors" do %>
          <i class="fas fa-cog mr-2"></i>Mes paramètres
        <% end %>
      </div>
    <% elsif @pending_resources.any? %>
      <div class="divide-y divide-white/5">
        <% @pending_resources.each do |resource| %>
          <div class="p-5">
            <div class="mb-3">
              <h3 class="font-semibold mb-1"><%= resource.title %></h3>
              <p class="text-gray-400 text-sm line-clamp-2"><%= resource.body.truncate(200) %></p>
            </div>
            <div class="flex flex-wrap items-center gap-2 mb-4">
              <span class="flex items-center gap-1.5 text-xs text-gray-400">
                <img src="<%= resource.user.profile_avatar %>" class="w-4 h-4 rounded-full">
                <%= resource.user.display_name %>
              </span>
              <% if resource.subject %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium border"
                      style="color:<%= resource.subject.accent_color %>;border-color:<%= resource.subject.accent_color %>33;background-color:<%= resource.subject.accent_color %>18;">
                  <i class="fas <%= resource.subject.icon %> text-[10px]"></i>
                  <%= resource.subject.name %>
                </span>
              <% end %>
              <% resource.tags.each do |tag| %>
                <span class="px-2 py-0.5 rounded-full text-xs text-gray-400 bg-white/5 border border-white/8">#<%= tag.name %></span>
              <% end %>
              <span class="text-xs text-gray-500 ml-auto">Soumise il y a <%= time_ago_in_words(resource.created_at) %></span>
            </div>
            <div class="flex gap-3">
              <%= button_to approve_mentor_resource_path(resource), method: :post,
                  class: "flex items-center gap-2 px-4 py-2 bg-emerald-500/20 hover:bg-emerald-500/30 text-emerald-400 rounded-xl text-sm font-medium transition-colors" do %>
                <i class="fas fa-check"></i> Approuver
              <% end %>
              <%= button_to reject_mentor_resource_path(resource), method: :post,
                  data: { turbo_confirm: "Refuser cette ressource ?" },
                  class: "flex items-center gap-2 px-4 py-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 rounded-xl text-sm font-medium transition-colors" do %>
                <i class="fas fa-times"></i> Refuser
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-10 text-center text-gray-400">
        <i class="fas fa-check-circle text-4xl mb-4 block text-emerald-400/50"></i>
        <p class="font-medium">Aucune ressource en attente dans tes domaines de compétence.</p>
      </div>
    <% end %>
  </div>
</div>
