<% content_for :title, "Espace Mentor" %>

<div class="max-w-4xl mx-auto py-8 px-4">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold mb-1">
        <i class="fas fa-chalkboard-teacher text-emerald-400 mr-3"></i>Mon espace Mentor
      </h1>
      <p class="text-gray-400">Gérez vos ressources pédagogiques partagées avec la communauté.</p>
    </div>
    <%= link_to new_resource_path, class: "px-4 py-2 bg-emerald-500 hover:bg-emerald-400 text-white rounded-lg font-medium transition-colors flex items-center gap-2" do %>
      <i class="fas fa-plus"></i> Nouvelle ressource
    <% end %>
  </div>

  <div class="glass rounded-2xl p-6 mb-6">
    <div class="flex items-center gap-4">
      <div class="text-center">
        <p class="text-3xl font-bold text-emerald-400"><%= @resources.count %></p>
        <p class="text-xs text-gray-400 mt-1">Ressource<%= @resources.count > 1 ? "s" : "" %> publiée<%= @resources.count > 1 ? "s" : "" %></p>
      </div>
    </div>
  </div>

  <% if @resources.any? %>
    <div class="space-y-4">
      <% @resources.each do |resource| %>
        <div class="glass rounded-2xl p-6 hover:bg-white/5 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <h2 class="text-lg font-semibold mb-1">
                <%= link_to resource.title, resource_path(resource), class: "hover:text-emerald-400 transition-colors" %>
              </h2>
              <p class="text-gray-400 text-sm line-clamp-2"><%= resource.body.truncate(150) %></p>
              <div class="flex items-center gap-3 mt-3 text-xs text-gray-500">
                <% if resource.subject %>
                  <span class="px-2 py-1 bg-white/10 rounded-full"><%= resource.subject.name %></span>
                <% end %>
                <span><%= time_ago_in_words(resource.created_at) %></span>
              </div>
            </div>
            <%= link_to resource_path(resource), class: "text-gray-400 hover:text-white transition-colors shrink-0" do %>
              <i class="fas fa-arrow-right"></i>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="glass rounded-2xl p-12 text-center text-gray-400">
      <i class="fas fa-book-open text-4xl mb-4 block text-emerald-400/50"></i>
      <p class="font-medium mb-2">Aucune ressource publiée</p>
      <p class="text-sm mb-4">Partagez vos connaissances avec la communauté StudyLink.</p>
      <%= link_to new_resource_path, class: "inline-block px-4 py-2 bg-emerald-500 hover:bg-emerald-400 text-white rounded-lg font-medium transition-colors" do %>
        Créer ma première ressource
      <% end %>
    </div>
  <% end %>
</div>
