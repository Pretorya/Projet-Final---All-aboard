<% content_for :title, "Connexion" %>

<div class="auth-shell">
  <div class="auth-grid max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center min-h-screen">
      <div>
        <%= link_to root_path, class: "inline-flex items-center gap-3 mb-8" do %>
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary to-accent flex items-center justify-center">
            <i class="fas fa-graduation-cap text-white text-lg"></i>
          </div>
          <span class="text-2xl font-bold gradient-text">StudyLink</span>
        <% end %>

        <p class="uppercase tracking-[0.3em] text-xs text-primary mb-4">Bon retour</p>
        <h1 class="text-5xl font-extrabold leading-tight mb-6">Reconnecte-toi à ton réseau d’entraide.</h1>
        <p class="text-lg text-gray-300 leading-relaxed max-w-xl">Retrouve ton feed, tes demandes, et tes conversations en direct depuis une seule interface.</p>
      </div>

      <div class="glass rounded-[2rem] p-8 md:p-10">
        <h2 class="text-3xl font-bold mb-2">Connexion</h2>
        <p class="text-gray-400 mb-8">Accède à ton espace StudyLink.</p>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div>
            <%= f.label :email, class: "block text-sm font-medium mb-2 text-gray-300" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary" %>
          </div>

          <div>
            <%= f.label :password, "Mot de passe", class: "block text-sm font-medium mb-2 text-gray-300" %>
            <%= f.password_field :password, autocomplete: "current-password", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-3 text-sm text-gray-300">
              <%= f.check_box :remember_me, class: "rounded bg-white/10 border-white/30 text-primary focus:ring-primary" %>
              <%= f.label :remember_me, "Se souvenir de moi" %>
            </div>
          <% end %>

          <%= f.submit "Se connecter", class: "w-full py-3 rounded-xl bg-primary hover:bg-primary/80 text-white font-medium transition-colors" %>
        <% end %>

        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
