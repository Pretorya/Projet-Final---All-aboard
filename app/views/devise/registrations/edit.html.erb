<% content_for :title, "Mon profil" %>

<div class="max-w-3xl mx-auto py-8">
  <div class="glass rounded-[2rem] p-8 md:p-10">
    <div class="flex items-center gap-4 mb-8">
      <img src="<%= current_user.profile_avatar %>" alt="<%= current_user.display_name %>" class="w-16 h-16 rounded-2xl border border-primary/40">
      <div>
        <h1 class="text-3xl font-bold">Mon profil</h1>
        <p class="text-gray-400">Mettez à jour vos informations et vos préférences.</p>
      </div>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :full_name, "Nom complet", class: "block text-sm font-medium mb-2 text-gray-300" %>
          <%= f.text_field :full_name, class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary" %>
        </div>
        <div>
          <%= f.label :education_level, "Niveau", class: "block text-sm font-medium mb-2 text-gray-300" %>
          <%= f.text_field :education_level, class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary" %>
        </div>
      </div>

      <div>
        <%= f.label :headline, class: "block text-sm font-medium mb-2 text-gray-300" %>
        <%= f.text_field :headline, class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary" %>
      </div>

      <div>
        <%= f.label :bio, class: "block text-sm font-medium mb-2 text-gray-300" %>
        <%= f.text_area :bio, rows: 4, class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary resize-none" %>
      </div>

      <div>
        <%= f.label :avatar_url, "Avatar URL", class: "block text-sm font-medium mb-2 text-gray-300" %>
        <%= f.url_field :avatar_url, class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary" %>
      </div>

      <div>
        <%= f.label :email, class: "block text-sm font-medium mb-2 text-gray-300" %>
        <%= f.email_field :email, autocomplete: "email", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary" %>
      </div>

      <div class="grid sm:grid-cols-3 gap-4">
        <div>
          <%= f.label :password, "Nouveau mot de passe", class: "block text-sm font-medium mb-2 text-gray-300" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary" %>
        </div>
        <div>
          <%= f.label :password_confirmation, "Confirmation", class: "block text-sm font-medium mb-2 text-gray-300" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary" %>
        </div>
        <div>
          <%= f.label :current_password, "Mot de passe actuel", class: "block text-sm font-medium mb-2 text-gray-300" %>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary" %>
        </div>
      </div>

      <div class="flex flex-wrap gap-3 pt-4">
        <%= f.submit "Mettre à jour", class: "px-6 py-3 rounded-xl bg-primary hover:bg-primary/80 text-white font-medium transition-colors" %>
        <%= button_to "Supprimer mon compte", registration_path(resource_name), data: { turbo_confirm: "Supprimer définitivement votre compte ?" }, method: :delete, class: "px-6 py-3 rounded-xl border border-red-400/30 text-red-300 hover:bg-red-500/10 transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
