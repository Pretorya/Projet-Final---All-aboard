<% if resource.errors.any? %>
  <div class="mb-6 rounded-2xl border border-red-400/20 bg-red-500/10 p-4">
    <p class="text-sm font-semibold text-red-300 mb-2">Le formulaire contient des erreurs.</p>
    <ul class="text-sm text-red-200 space-y-1">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
