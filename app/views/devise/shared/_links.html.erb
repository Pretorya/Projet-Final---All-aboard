<div class="mt-6 pt-6 border-t border-white/10 text-sm text-gray-400 space-y-3">
  <% if controller_name != "sessions" %>
    <p><%= link_to "Se connecter", new_session_path(resource_name), class: "text-primary hover:text-white transition-colors" %></p>
  <% end %>
  <% if devise_mapping.registerable? && controller_name != "registrations" %>
    <p><%= link_to "Créer un compte", new_registration_path(resource_name), class: "text-primary hover:text-white transition-colors" %></p>
  <% end %>
  <% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <p><%= link_to "Mot de passe oublié ?", new_password_path(resource_name), class: "text-primary hover:text-white transition-colors" %></p>
  <% end %>
</div>
