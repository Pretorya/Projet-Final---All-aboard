<% content_for :title, "Événements" %>

<div class="max-w-4xl mx-auto py-8 px-4">
  <div class="mb-8">
    <h1 class="text-3xl font-bold mb-2">
      <i class="fas fa-calendar-alt text-accent mr-3"></i>Événements
    </h1>
    <p class="text-gray-400">Hackathons, portes ouvertes, conférences et forums sélectionnés pour vous.</p>
  </div>

  <%# Filtre par catégorie %>
  <div class="flex flex-wrap gap-2 mb-8">
    <%= link_to events_path, class: "px-3 py-1 rounded-full text-sm transition-colors #{params[:subject_id].blank? ? 'bg-primary text-white' : 'bg-white/10 text-gray-300 hover:bg-white/20'}" do %>
      Tous
    <% end %>
    <%= link_to events_path(subject_id: "general"), class: "px-3 py-1 rounded-full text-sm transition-colors #{params[:subject_id] == 'general' ? 'bg-primary text-white' : 'bg-white/10 text-gray-300 hover:bg-white/20'}" do %>
      Général
    <% end %>
    <% @subjects.each do |subject| %>
      <%= link_to events_path(subject_id: subject.id), class: "px-3 py-1 rounded-full text-sm transition-colors #{params[:subject_id] == subject.id.to_s ? 'bg-primary text-white' : 'bg-white/10 text-gray-300 hover:bg-white/20'}" do %>
        <%= subject.name %>
      <% end %>
    <% end %>
  </div>

  <%# À venir %>
  <% if @upcoming.any? %>
    <h2 class="text-lg font-semibold mb-4 text-white">
      <i class="fas fa-hourglass-half text-accent mr-2"></i>À venir
    </h2>
    <div class="space-y-4 mb-10">
      <% @upcoming.each do |event| %>
        <%= render "event_card", event: event %>
      <% end %>
    </div>
  <% end %>

  <%# Passés %>
  <% if @past.any? %>
    <h2 class="text-lg font-semibold mb-4 text-gray-400">
      <i class="fas fa-history mr-2"></i>Événements passés
    </h2>
    <div class="space-y-4 opacity-60">
      <% @past.each do |event| %>
        <%= render "event_card", event: event %>
      <% end %>
    </div>
  <% end %>

  <% if @upcoming.empty? && @past.empty? %>
    <div class="glass rounded-2xl p-12 text-center text-gray-400">
      <i class="fas fa-calendar-times text-4xl mb-4 block text-accent/50"></i>
      <p class="font-medium mb-2">Aucun événement pour le moment.</p>
      <p class="text-sm">Les événements sont mis à jour automatiquement chaque jour depuis Eventbrite.</p>
    </div>
  <% end %>
</div>
