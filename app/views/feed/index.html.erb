<% content_for :title, "AllAboard" %>

<div class="animate-fade-in">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
    <div class="hidden lg:block lg:col-span-3 space-y-6 sticky top-24">
      <%= render "feed/recently_viewed", recently_viewed: @recently_viewed %>

      <div class="glass rounded-2xl p-6">
        <h3 class="font-semibold mb-4 text-gray-300">Top contributeurs</h3>
        <div class="space-y-4">
          <% @top_contributors.each do |user| %>
            <div class="flex items-center gap-3">
              <img src="<%= user.profile_avatar %>" alt="<%= user.display_name %>" class="w-10 h-10 rounded-full">
              <div class="flex-1">
                <p class="font-medium text-sm"><%= link_to user.display_name, user_path(user), class: "hover:text-primary transition-colors", data: { turbo_frame: "_top" } %></p>
                <p class="text-xs text-gray-500"><%= user.contribution_count %> aides données</p>
              </div>
              <span class="text-yellow-400 text-xs"><i class="fas fa-star"></i> <%= format("%.1f", user.rating) %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-span-1 lg:col-span-6 space-y-6">
      <div class="flex flex-wrap gap-4 justify-center">
        <button type="button" class="w-20 flex flex-col items-center gap-2 cursor-pointer group" data-action="click->modal#open" data-modal-id="request-subject-modal">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-primary to-accent p-[2px] group-hover:scale-110 transition-transform">
            <div class="w-full h-full rounded-2xl bg-surface flex items-center justify-center">
              <i class="fas fa-plus text-primary"></i>
            </div>
          </div>
          <span class="text-xs text-gray-400">Nouveau</span>
        </button>

        <% @subjects.first(5).each do |subject| %>
          <%= link_to authenticated_root_path(subject: subject.slug), class: "w-20 flex flex-col items-center gap-2 cursor-pointer group" do %>
            <div class="w-16 h-16 rounded-2xl border flex items-center justify-center transition-transform group-hover:scale-110" style="background-color: <%= "#{subject.accent_color}1F" %>; border-color: <%= "#{subject.accent_color}4D" %>; color: <%= subject.accent_color %>;">
              <i class="fas <%= subject.icon %> text-xl"></i>
            </div>
            <span class="text-xs text-gray-400"><%= subject.name %></span>
          <% end %>
        <% end %>
      </div>

      <div class="glass rounded-2xl p-4 flex items-center gap-4">
        <img src="<%= current_user.profile_avatar %>" alt="<%= current_user.display_name %>" class="w-10 h-10 rounded-full">
        <button type="button" data-action="modal#open" class="flex-1 text-left bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-gray-400 hover:border-primary transition-colors">
          Demander de l'aide sur un sujet...
        </button>
        <button type="button" data-action="modal#open" class="p-3 rounded-xl bg-primary/20 text-primary hover:bg-primary/30 transition-colors">
          <i class="fas fa-paper-plane"></i>
        </button>
      </div>

      <div class="space-y-6">
        <% if @posts.any? %>
          <%= render @posts %>
        <% else %>
          <div class="glass rounded-2xl p-10 text-center text-gray-400">
            <i class="fas fa-sparkles text-4xl text-primary mb-4"></i>
            <p>Aucune requête ne correspond encore à ce filtre.</p>
          </div>
        <% end %>
      </div>
    </div>

    <div class="hidden lg:block lg:col-span-3 space-y-6 sticky top-24">
      <div class="glass rounded-2xl p-6">
        <div class="flex items-center gap-2 mb-4">
          <i class="fas fa-magnifying-glass text-primary text-sm"></i>
          <h3 class="font-semibold text-gray-300">Rechercher</h3>
        </div>
        <%= form_with url: feed_path, method: :get, data: { turbo: false } do |f| %>
          <div class="relative">
            <%= f.search_field :q,
                value: @search_query,
                placeholder: "Titre, contenu, tag…",
                class: "w-full bg-white/5 border border-white/10 rounded-xl pl-4 pr-10 py-3 text-sm focus:outline-none focus:border-primary transition-colors placeholder-gray-500",
                autocomplete: "off" %>
            <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 hover:text-primary transition-colors">
              <i class="fas fa-arrow-right text-sm"></i>
            </button>
          </div>
          <% if @search_query.present? %>
            <div class="mt-3 flex items-center justify-between">
              <p class="text-xs text-gray-400">
                <span class="text-primary font-medium"><%= @posts.size %></span> résultat<%= "s" if @posts.size != 1 %> pour
                <span class="text-white/70 italic">"<%= @search_query %>"</span>
              </p>
              <%= link_to feed_path, class: "text-xs text-gray-500 hover:text-gray-300 transition-colors" do %>
                <i class="fas fa-times mr-1"></i>Effacer
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="glass rounded-2xl p-6">
        <h3 class="font-semibold mb-4 text-gray-300">Vos statistiques</h3>
        <div class="grid grid-cols-2 gap-4">
          <div class="text-center p-4 bg-white/5 rounded-xl">
            <p class="text-2xl font-bold text-primary"><%= current_user.contribution_count %></p>
            <p class="text-xs text-gray-500 mt-1">Aides données</p>
          </div>
          <div class="text-center p-4 bg-white/5 rounded-xl">
            <p class="text-2xl font-bold text-accent"><%= current_user.posts.count %></p>
            <p class="text-xs text-gray-500 mt-1">Requêtes</p>
          </div>
          <div class="text-center p-4 bg-white/5 rounded-xl col-span-2">
            <p class="text-2xl font-bold text-yellow-400"><%= format("%.1f", current_user.rating) %></p>
            <p class="text-xs text-gray-500 mt-1">Note moyenne</p>
            <div class="flex justify-center gap-1 mt-2 text-yellow-400 text-xs">
              <i class="fas fa-star"></i>
              <i class="fas fa-star"></i>
              <i class="fas fa-star"></i>
              <i class="fas fa-star"></i>
              <i class="fas fa-star-half-alt"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
