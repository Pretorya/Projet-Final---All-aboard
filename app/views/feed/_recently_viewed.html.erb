<div id="recently_viewed" class="glass rounded-2xl p-6">
  <h3 class="font-semibold mb-4 text-gray-300 flex items-center gap-2">
    <i class="fas fa-history text-primary text-sm"></i>
    Consultés récemment
  </h3>
  <% if recently_viewed.any? %>
    <div class="space-y-3">
      <% recently_viewed.each do |post| %>
        <%= link_to post_path(post),
                    class: "flex items-start gap-3 p-2 rounded-xl hover:bg-white/5 transition-colors group",
                    data: {
                      turbo_frame: "_top",
                      controller: "track-view",
                      "track-view-url-value": track_view_post_path(post),
                      action: "click->track-view#track"
                    } do %>
          <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5"
               style="background-color: <%= "#{post.subject.accent_color}20" %>; color: <%= post.subject.accent_color %>">
            <i class="fas <%= post.subject.icon %> text-xs"></i>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-medium text-gray-200 group-hover:text-primary transition-colors line-clamp-2 leading-snug"><%= post.title %></p>
            <p class="text-xs text-gray-500 mt-0.5"><%= post.user.display_name %></p>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-4">
      <i class="fas fa-mouse-pointer text-2xl text-gray-600 mb-2"></i>
      <p class="text-xs text-gray-500">Les posts que vous consultez apparaîtront ici.</p>
    </div>
  <% end %>
</div>
