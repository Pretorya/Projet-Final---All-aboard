<% content_for :title, "Créer un administrateur" %>

<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">
    <div class="glass rounded-2xl p-8">
      <div class="text-center mb-8">
        <div class="w-16 h-16 rounded-xl bg-gradient-to-br from-primary to-accent flex items-center justify-center mx-auto mb-4">
          <i class="fas fa-crown text-white text-2xl"></i>
        </div>
        <h1 class="text-3xl font-bold mb-2">Créer un administrateur</h1>
        <p class="text-gray-400">Inscrivez un nouveau compte administrateur</p>
      </div>

      <% if @user.errors.any? %>
        <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 rounded-lg">
          <p class="text-red-400 font-semibold mb-2"><%= pluralize(@user.errors.count, "erreur") %> détectée(s) :</p>
          <ul class="list-disc list-inside text-red-400 text-sm space-y-1">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @user, url: admin_setup_create_admin_path, method: :post, local: true do |f| %>
        <div class="mb-6">
          <%= f.label :full_name, "Nom complet *", class: "block text-sm font-medium mb-2 text-gray-300" %>
          <%= f.text_field :full_name, placeholder: "ex: Jean Dupont", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary text-white placeholder-gray-500" %>
        </div>

        <div class="mb-6">
          <%= f.label :email, "Adresse email *", class: "block text-sm font-medium mb-2 text-gray-300" %>
          <%= f.email_field :email, placeholder: "ex: admin@example.com", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary text-white placeholder-gray-500" %>
        </div>

        <div class="grid grid-cols-2 gap-3 mb-6">
          <div>
            <%= f.label :password, "Mot de passe *", class: "block text-sm font-medium mb-2 text-gray-300" %>
            <%= f.password_field :password, placeholder: "••••••••", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary text-white placeholder-gray-500" %>
          </div>
          <div>
            <%= f.label :password_confirmation, "Confirmer *", class: "block text-sm font-medium mb-2 text-gray-300" %>
            <%= f.password_field :password_confirmation, placeholder: "••••••••", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary text-white placeholder-gray-500" %>
          </div>
        </div>

        <div class="p-3 bg-yellow-500/10 border border-yellow-500/30 rounded-lg mb-6">
          <p class="text-yellow-400 text-sm flex items-start gap-2">
            <i class="fas fa-crown mt-0.5 flex-shrink-0"></i>
            <span>Ce compte aura les droits administrateur complets</span>
          </p>
        </div>

        <%= f.submit "Créer l'administrateur", class: "w-full px-6 py-3 rounded-xl bg-primary hover:bg-primary/80 text-white font-medium transition-colors" %>
      <% end %>

      <div class="mt-6 text-center">
        <%= link_to "Se connecter", new_user_session_path, class: "text-primary hover:underline text-sm" %>
      </div>

      <div class="mt-6 p-3 bg-white/5 rounded-lg border border-white/10">
        <p class="text-xs text-gray-500">
          <i class="fas fa-info-circle mr-2"></i>
          Cette page est protégée par une clé d'administration secrète.
        </p>
      </div>
    </div>
  </div>
</div>
