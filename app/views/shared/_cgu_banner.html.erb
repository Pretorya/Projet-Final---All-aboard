<% if @requires_cgu_acceptance %>
  <div class="fixed inset-0 z-[9999] bg-darker/90 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="glass rounded-2xl p-8 max-w-lg w-full shadow-2xl border border-primary/20">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary to-accent flex items-center justify-center flex-shrink-0">
          <i class="fas fa-graduation-cap text-white"></i>
        </div>
        <div>
          <h2 class="text-xl font-bold">Bienvenue sur StudyLink</h2>
          <p class="text-sm text-gray-400">Avant de continuer, une dernière étape</p>
        </div>
      </div>

      <div class="bg-white/5 rounded-xl p-4 mb-6 border border-white/10">
        <p class="text-sm text-gray-300 leading-relaxed">
          Pour accéder à StudyLink, vous devez lire et accepter nos
          <%= link_to "Conditions Générales d'Utilisation", legal_cgu_path, target: "_blank", class: "text-primary hover:underline font-medium" %>,
          notre <%= link_to "Politique de confidentialité", legal_privacy_path, target: "_blank", class: "text-primary hover:underline font-medium" %>
          ainsi que nos <%= link_to "Mentions légales", legal_mentions_path, target: "_blank", class: "text-primary hover:underline font-medium" %>.
        </p>
      </div>

      <form action="<%= accept_cgu_path %>" method="post" data-turbo="false">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <label class="flex items-start gap-3 cursor-pointer group mb-6">
          <input type="checkbox" id="cgu_checkbox" name="cgu_accepted" value="1" class="mt-1 w-5 h-5 rounded border border-white/30 bg-white/5 text-primary focus:ring-primary flex-shrink-0 cursor-pointer">
          <span class="text-sm text-gray-300 group-hover:text-white transition-colors leading-relaxed">
            J'ai lu et j'accepte les
            <span class="text-white font-medium">Conditions Générales d'Utilisation</span>,
            la <span class="text-white font-medium">Politique de confidentialité</span>
            et les <span class="text-white font-medium">Mentions légales</span> de StudyLink.
          </span>
        </label>

        <button
          type="submit"
          id="cgu_submit"
          disabled
          class="w-full px-6 py-3 rounded-xl bg-primary/40 text-white/50 font-medium transition-all duration-200 cursor-not-allowed"
        >
          Accéder à StudyLink
        </button>
      </form>
    </div>
  </div>

  <script>
    (function() {
      const checkbox = document.getElementById('cgu_checkbox');
      const btn = document.getElementById('cgu_submit');
      if (!checkbox || !btn) return;

      checkbox.addEventListener('change', function() {
        if (this.checked) {
          btn.disabled = false;
          btn.className = 'w-full px-6 py-3 rounded-xl bg-primary hover:bg-primary/80 text-white font-medium transition-all duration-200 cursor-pointer';
        } else {
          btn.disabled = true;
          btn.className = 'w-full px-6 py-3 rounded-xl bg-primary/40 text-white/50 font-medium transition-all duration-200 cursor-not-allowed';
        }
      });
    })();
  </script>
<% end %>
