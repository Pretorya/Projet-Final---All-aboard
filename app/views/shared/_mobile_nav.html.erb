<div class="md:hidden fixed bottom-0 w-full glass border-t border-white/10 z-50 safe-bottom">
  <div class="flex justify-around items-center h-16">
    <%= link_to authenticated_root_path, class: mobile_nav_classes(:feed) do %>
      <i class="fas fa-home text-xl"></i>
      <span class="text-xs">Accueil</span>
    <% end %>

    <%= link_to explore_path, class: mobile_nav_classes(:explore) do %>
      <i class="fas fa-compass text-xl"></i>
      <span class="text-xs">Explorer</span>
    <% end %>

    <button type="button" data-action="modal#open" class="flex flex-col items-center gap-1 -mt-8">
      <span class="w-14 h-14 rounded-full bg-gradient-to-br from-primary to-accent flex items-center justify-center shadow-lg shadow-primary/30">
        <i class="fas fa-plus text-white text-xl"></i>
      </span>
    </button>

    <%= link_to conversations_path, class: "#{mobile_nav_classes(:messages)} relative" do %>
      <i class="fas fa-comment-dots text-xl"></i>
      <% if @conversation_count.to_i.positive? %>
        <span class="absolute -top-1 right-0 w-4 h-4 bg-accent text-[10px] rounded-full flex items-center justify-center">
          <%= @conversation_count %>
        </span>
      <% end %>
      <span class="text-xs">Messages</span>
    <% end %>

    <%= link_to edit_user_registration_path, class: "flex flex-col items-center gap-1 text-gray-400 relative" do %>
      <div class="relative">
        <img src="<%= current_user.profile_avatar %>" alt="<%= current_user.display_name %>" class="w-6 h-6 rounded-full border border-white/30">
        <% if current_user.mentor? && @mentor_pending_count.to_i > 0 %>
          <span class="absolute -top-1 -right-1 w-3.5 h-3.5 bg-emerald-400 rounded-full border border-darker"></span>
        <% end %>
      </div>
      <span class="text-xs">Profil</span>
    <% end %>
  </div>
</div>
