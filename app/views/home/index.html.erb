<% content_for :title, "StudyLink" %>

<div class="auth-shell">
  <div class="landing-grid absolute inset-0"></div>
  <div class="auth-grid max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-center mb-12">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary to-accent flex items-center justify-center">
          <i class="fas fa-graduation-cap text-white text-lg"></i>
        </div>
        <span class="text-2xl font-bold gradient-text">StudyLink</span>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-center min-h-[78vh]">
      <div>
        <p class="uppercase tracking-[0.3em] text-xs text-primary mb-4">Entraide étudiante en temps réel</p>
        <h1 class="text-5xl md:text-6xl font-extrabold leading-tight mb-6">
          L’espace où les étudiants
          <span class="gradient-text">s’aident vraiment</span>.
        </h1>
        <p class="text-lg text-gray-300 leading-relaxed max-w-2xl mb-8">
          Publiez une requête, recevez des réponses ciblées, puis basculez instantanément vers une messagerie temps réel pour aller jusqu’à la résolution.
        </p>

        <div class="flex flex-wrap gap-3 mb-8">
          <span class="subject-chip px-4 py-2 rounded-full text-sm text-gray-200"><i class="fas fa-bolt text-primary mr-2"></i>Feed social ciblé</span>
          <span class="subject-chip px-4 py-2 rounded-full text-sm text-gray-200"><i class="fas fa-comments text-accent mr-2"></i>Chat temps réel</span>
          <span class="subject-chip px-4 py-2 rounded-full text-sm text-gray-200"><i class="fas fa-layer-group text-cyan-400 mr-2"></i>Exploration par matière</span>
        </div>

      </div>

      <div class="glass rounded-[2rem] p-8 hero-panel">
        <div class="mb-8">
          <h2 class="text-2xl font-bold">Connexion</h2>
          <p class="text-sm text-gray-400 mt-1">Rentre dans ton compte StudyLink</p>
        </div>

        <% if flash[:alert] %>
          <div class="mb-4 text-sm text-red-400"> <%= flash[:alert] %> </div>
        <% end %>
        <% if flash[:notice] %>
          <div class="mb-4 text-sm text-green-400"> <%= flash[:notice] %> </div>
        <% end %>

        <%= form_with url: user_session_path, method: :post, local: true do |f| %>
          <div class="space-y-4">
            <div>
              <%= f.label :email, "Email", class: "block text-sm text-gray-400 mb-1" %>
              <%= f.email_field :email, name: "user[email]", autofocus: true, autocomplete: "email", placeholder: "toi@exemple.com", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary transition-colors" %>
            </div>
            <div>
              <%= f.label :password, "Mot de passe", class: "block text-sm text-gray-400 mb-1" %>
              <%= f.password_field :password, name: "user[password]", autocomplete: "current-password", placeholder: "••••••••", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary transition-colors" %>
            </div>
            <div class="flex items-center gap-2 text-sm text-gray-300">
              <%= f.check_box :remember_me, name: "user[remember_me]", class: "rounded bg-white/10 border-white/30 text-primary focus:ring-primary" %>
              <%= f.label :remember_me, "Se souvenir de moi" %>
            </div>
            <%= f.submit "Se connecter", class: "w-full mt-2 px-6 py-3 rounded-2xl bg-primary hover:bg-primary/80 text-white font-medium transition-colors cursor-pointer" %>
          </div>
        <% end %>

        <p class="text-center text-sm text-gray-500 mt-6">
          Pas encore de compte ?
          <%= link_to "Inscris-toi", new_user_registration_path, class: "text-primary hover:underline" %>
        </p>
      </div>
    </div>
  </div>
</div>
