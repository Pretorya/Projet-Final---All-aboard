<% peer = conversation.other_participant(current_user) %>
<% active = local_assigns[:active] %>
<% unread_count = conversation.unread_count_for(current_user) %>
<% last_message = conversation.last_message %>

<%= link_to conversation_path(conversation), class: "flex items-center gap-3 p-3 rounded-xl cursor-pointer transition-colors #{active ? "bg-primary/20 border border-primary/30" : "hover:bg-white/5"}" do %>
  <div class="relative">
    <img src="<%= peer.profile_avatar %>" alt="<%= peer.display_name %>" class="w-12 h-12 rounded-full">
    <span class="absolute bottom-0 right-0 w-3 h-3 rounded-full border-2 border-surface <%= conversation_online?(peer) ? "bg-green-500" : "bg-gray-500" %>"></span>
  </div>
  <div class="flex-1 min-w-0">
    <div class="flex justify-between items-center mb-1 gap-3">
      <h4 class="font-semibold text-sm truncate"><%= peer.display_name %></h4>
      <span class="text-xs text-gray-500"><%= last_message ? relative_time(last_message.created_at) : relative_time(conversation.created_at) %></span>
    </div>
    <p class="text-xs text-gray-400 truncate"><%= last_message&.body.presence || conversation.topic.presence || "Commencez la conversation" %></p>
  </div>
  <% if unread_count.positive? %>
    <span class="min-w-5 h-5 px-1 bg-accent rounded-full flex items-center justify-center text-[10px]"><%= unread_count %></span>
  <% end %>
<% end %>
