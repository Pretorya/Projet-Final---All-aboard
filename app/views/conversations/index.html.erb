<% content_for :title, "Messages" %>

<div class="animate-fade-in h-[calc(100vh-8rem)]">
  <div class="glass rounded-2xl h-full overflow-hidden flex">
    <div class="<%= @conversation.present? && params[:id].present? ? "hidden md:flex" : "flex" %> w-full md:w-80 border-r border-white/10 flex-col">
      <div class="p-4 border-b border-white/10">
        <h2 class="text-xl font-bold mb-4">Messages</h2>
        <div class="relative">
          <input type="text" placeholder="Rechercher..." class="w-full bg-white/5 border border-white/10 rounded-xl pl-10 pr-4 py-2 text-sm focus:outline-none focus:border-primary">
          <i class="fas fa-search absolute left-3 top-2.5 text-gray-500"></i>
        </div>
      </div>

      <div class="flex-1 overflow-y-auto">
        <div class="p-3 space-y-1">
          <% @conversations.each do |conversation| %>
            <%= render "conversation", conversation: conversation, active: conversation == @conversation %>
          <% end %>
        </div>
      </div>
    </div>

    <% if @conversation.present? %>
      <% peer = @conversation.other_participant(current_user) %>
      <div class="<%= params[:id].present? ? "flex" : "hidden md:flex" %> flex-1 flex-col bg-black/20">
        <%= turbo_stream_from @conversation %>

        <div class="p-4 border-b border-white/10 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <%= link_to conversations_path, class: "md:hidden text-gray-400 hover:text-white" do %>
              <i class="fas fa-arrow-left"></i>
            <% end %>
            <img src="<%= peer.profile_avatar %>" alt="<%= peer.display_name %>" class="w-10 h-10 rounded-full">
            <div>
              <h4 class="font-semibold"><%= peer.display_name %></h4>
              <p class="text-xs <%= conversation_online?(peer) ? "text-green-400" : "text-gray-500" %>"><%= conversation_online?(peer) ? "En ligne" : "Hors ligne" %></p>
            </div>
          </div>
          <div class="hidden md:flex items-center gap-3 text-gray-400">
            <button class="hover:text-white p-2"><i class="fas fa-phone"></i></button>
            <button class="hover:text-white p-2"><i class="fas fa-video"></i></button>
            <button class="hover:text-white p-2"><i class="fas fa-info-circle"></i></button>
          </div>
        </div>

        <div id="<%= dom_id(@conversation) %>_messages" class="flex-1 overflow-y-auto p-4 space-y-4" data-controller="conversation-messages" data-conversation-messages-current-user-id-value="<%= current_user.id %>">
          <div class="flex justify-center">
            <span class="text-xs text-gray-500 bg-white/5 px-3 py-1 rounded-full">Aujourd'hui</span>
          </div>
          <%= render @messages %>
        </div>

        <div class="p-4 border-t border-white/10">
          <%= form_with model: [@conversation, @message], class: "flex items-center gap-3", data: { controller: "message-form", action: "turbo:submit-end->message-form#reset" } do |form| %>
            <button type="button" class="text-gray-400 hover:text-white p-2 hidden md:block"><i class="fas fa-paperclip"></i></button>
            <%= form.text_field :body, placeholder: "Écrire un message...", class: "flex-1 bg-white/5 border border-white/10 rounded-full px-4 py-3 text-sm focus:outline-none focus:border-primary", autocomplete: "off", data: { "message-form-target": "input" } %>
            <button type="button" class="text-gray-400 hover:text-primary p-2 hidden md:block"><i class="fas fa-microphone"></i></button>
            <%= form.button class: "bg-primary hover:bg-primary/80 text-white p-3 rounded-full transition-colors" do %>
              <i class="fas fa-paper-plane"></i>
            <% end %>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="hidden md:flex flex-1 items-center justify-center bg-black/20">
        <div class="text-center text-gray-500">
          <i class="fas fa-comments text-4xl mb-3"></i>
          <p>Sélectionnez une conversation</p>
        </div>
      </div>
    <% end %>
  </div>
</div>
