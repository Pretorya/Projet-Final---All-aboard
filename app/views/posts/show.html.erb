<% content_for :title, @post.title %>

<div class="max-w-3xl mx-auto py-8 animate-fade-in">
  <%= link_to authenticated_root_path, class: "inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors mb-6" do %>
    <i class="fas fa-arrow-left"></i>
    Retour au feed
  <% end %>

  <%# Post card (likes / bookmarks / message privé fonctionnels via turbo_frame) %>
  <%= render "posts/post", post: @post, show_page: true %>

  <%# Section commentaires complète %>
  <div class="glass rounded-2xl mt-4">
    <div class="p-5 border-b border-white/10 flex items-center justify-between">
      <h2 class="font-semibold flex items-center gap-2">
        <i class="far fa-comments text-primary"></i>
        <%= @post.comments_count %> réponse<%= "s" if @post.comments_count != 1 %>
      </h2>
    </div>

    <div id="post_<%= @post.id %>_comments" class="divide-y divide-white/5">
      <% visible_comments = current_user.admin? ? @post.comments : @post.comments.reject(&:flagged_for_moderation?) %>
      <% if visible_comments.any? %>
        <% visible_comments.each do |comment| %>
          <div class="p-5">
            <%= render "comments/comment", comment: comment %>
          </div>
        <% end %>
      <% else %>
        <div class="p-8 text-center text-gray-500">
          <i class="far fa-comment text-3xl mb-3"></i>
          <p class="text-sm">Aucune réponse pour le moment. Soyez le premier !</p>
        </div>
      <% end %>
    </div>

    <div class="p-5 border-t border-white/10 bg-white/3 rounded-b-2xl">
      <%= form_with model: Comment.new, url: comments_path, class: "flex gap-3 items-start" do |form| %>
        <%= form.hidden_field :post_id, value: @post.id %>
        <img src="<%= current_user.profile_avatar %>" alt="<%= current_user.display_name %>" class="w-9 h-9 rounded-full flex-shrink-0 mt-1">
        <div class="flex-1 flex flex-col gap-2">
          <%= form.text_area :body,
              placeholder: "Écrire une réponse...",
              rows: 3,
              class: "w-full bg-black/30 border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary resize-none" %>

          <%# Bloc de code optionnel %>
          <details class="group">
            <summary class="text-xs text-gray-500 hover:text-gray-300 cursor-pointer select-none flex items-center gap-1.5 py-1 w-fit">
              <i class="fas fa-code text-[10px]"></i>
              Ajouter un bloc de code
              <i class="fas fa-chevron-down text-[10px] group-open:rotate-180 transition-transform"></i>
            </summary>
            <div class="mt-2 space-y-2">
              <div class="flex items-center justify-between">
                <span class="text-xs text-gray-500">Langage</span>
                <%= form.select :code_language,
                    [
                      ["— Langage —",  "plaintext"],
                      ["Python",       "python"],
                      ["JavaScript",   "javascript"],
                      ["TypeScript",   "typescript"],
                      ["HTML",         "html"],
                      ["CSS",          "css"],
                      ["Ruby",         "ruby"],
                      ["Java",         "java"],
                      ["C",            "c"],
                      ["C++",          "cpp"],
                      ["C#",           "csharp"],
                      ["PHP",          "php"],
                      ["Go",           "go"],
                      ["Rust",         "rust"],
                      ["SQL",          "sql"],
                      ["Bash / Shell", "bash"],
                      ["R",            "r"],
                      ["MATLAB",       "matlab"],
                      ["LaTeX",        "latex"],
                      ["JSON",         "json"],
                      ["Texte brut",   "plaintext"],
                    ],
                    {},
                    class: "bg-black/40 border border-white/10 rounded-lg px-3 py-1 text-xs text-gray-300 focus:outline-none focus:border-primary" %>
              </div>
              <%= form.text_area :code_snippet,
                  rows: 5,
                  placeholder: "Colle ton code ici...",
                  class: "w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm font-mono focus:outline-none focus:border-primary resize-y" %>
            </div>
          </details>

          <div class="flex justify-end">
            <%= form.submit "Répondre", class: "px-5 py-2 rounded-xl bg-primary hover:bg-primary/80 text-sm font-medium transition-colors cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
