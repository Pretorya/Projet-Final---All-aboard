<% content_for :title, "Modifier le post" %>

<div class="max-w-2xl mx-auto py-8 animate-fade-in">
  <%= link_to post_path(@post), class: "inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors mb-6", data: { turbo_frame: "_top" } do %>
    <i class="fas fa-arrow-left"></i>
    Retour au post
  <% end %>

  <div class="glass rounded-2xl p-6">
    <h1 class="text-xl font-bold mb-6">Modifier la requête</h1>

    <%= form_with model: @post, url: post_path(@post), method: :patch, class: "space-y-5" do |form| %>
      <% if @post.errors.any? %>
        <div class="p-4 bg-red-500/10 border border-red-500/30 rounded-xl text-red-400 text-sm">
          <% @post.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <%= form.label :title, "Titre", class: "block text-sm font-medium mb-2 text-gray-300" %>
        <%= form.text_field :title,
            placeholder: "Ex: Aide pour équation différentielle",
            class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary" %>
      </div>

      <div>
        <%= form.label :body, "Description", class: "block text-sm font-medium mb-2 text-gray-300" %>
        <%= form.text_area :body, rows: 5,
            placeholder: "Décrivez votre problème en détail...",
            class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary resize-none" %>
      </div>

      <div>
        <div class="flex items-center justify-between mb-2">
          <%= form.label :code_snippet, "Bloc de code", class: "text-sm font-medium text-gray-300" %>
          <%= form.select :code_language,
              [
                ["— Langage —",  "plaintext"],
                ["Python",       "python"],
                ["JavaScript",   "javascript"],
                ["TypeScript",   "typescript"],
                ["HTML",         "html"],
                ["CSS",          "css"],
                ["Ruby",         "ruby"],
                ["Java",         "java"],
                ["C",            "c"],
                ["C++",          "cpp"],
                ["C#",           "csharp"],
                ["PHP",          "php"],
                ["Go",           "go"],
                ["Rust",         "rust"],
                ["SQL",          "sql"],
                ["Bash / Shell", "bash"],
                ["R",            "r"],
                ["MATLAB",       "matlab"],
                ["LaTeX",        "latex"],
                ["JSON",         "json"],
                ["Texte brut",   "plaintext"],
              ],
              {},
              class: "bg-black/40 border border-white/10 rounded-lg px-3 py-1.5 text-xs text-gray-300 focus:outline-none focus:border-primary" %>
        </div>
        <%= form.text_area :code_snippet, rows: 4,
            placeholder: "Optionnel — colle ton code ici...",
            class: "w-full bg-black/30 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary resize-none font-mono text-sm" %>
      </div>

      <div>
        <div class="flex items-center gap-2 mb-2">
          <span class="text-sm font-medium text-gray-300">Tag principal</span>
          <span class="text-xs text-gray-500 bg-white/5 px-2 py-0.5 rounded-full">1 seul</span>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
          <%= form.collection_radio_buttons :subject_id, @subjects, :id, :name do |builder| %>
            <label class="block cursor-pointer">
              <%= builder.radio_button class: "peer sr-only" %>
              <span class="block p-3 rounded-lg bg-white/5 border border-white/10 text-sm hover:border-primary transition-colors text-center peer-checked:bg-primary peer-checked:border-primary peer-checked:text-white">
                <i class="fas <%= builder.object.icon %> mr-2"></i><%= builder.text %>
              </span>
            </label>
          <% end %>
        </div>
      </div>

      <div>
        <div class="flex items-center gap-2 mb-2">
          <span class="text-sm font-medium text-gray-300">Sous-tags</span>
          <span class="text-xs text-gray-500 bg-white/5 px-2 py-0.5 rounded-full">optionnel · max 6</span>
        </div>
        <%= form.text_field :tag_list,
            placeholder: "Ex : intégrales, limite, convergence — séparés par des virgules",
            class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary text-sm" %>
      </div>

      <div class="flex items-center gap-2 p-3 bg-orange-500/10 border border-orange-500/20 rounded-xl">
        <%= form.check_box :urgent, class: "rounded bg-white/10 border-white/30 text-primary focus:ring-primary" %>
        <%= form.label :urgent, class: "text-sm text-orange-400 flex items-center gap-2 cursor-pointer" do %>
          <i class="fas fa-exclamation-circle"></i> Marquer comme urgent
        <% end %>
      </div>

      <div class="flex gap-3 pt-2">
        <%= link_to "Annuler", post_path(@post),
            class: "flex-1 py-3 rounded-xl border border-white/20 hover:bg-white/5 transition-colors text-center",
            data: { turbo_frame: "_top" } %>
        <%= form.submit "Enregistrer les modifications",
            class: "flex-1 py-3 rounded-xl bg-primary hover:bg-primary/80 text-white font-medium transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
