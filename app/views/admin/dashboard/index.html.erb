<% content_for :title, "Admin - Tableau de bord" %>

<div class="max-w-7xl mx-auto py-8 px-4">
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-2">Tableau de bord Admin</h1>
    <p class="text-gray-400">Gérez l'application et les utilisateurs</p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
    <div class="glass rounded-2xl p-6 text-center">
      <p class="text-4xl font-bold text-primary"><%= @total_posts %></p>
      <p class="text-sm text-gray-400 mt-2">Posts publiés</p>
    </div>
    <div class="glass rounded-2xl p-6 text-center">
      <p class="text-4xl font-bold text-accent"><%= @total_users %></p>
      <p class="text-sm text-gray-400 mt-2">Utilisateurs</p>
    </div>
    <div class="glass rounded-2xl p-6 text-center">
      <p class="text-4xl font-bold text-yellow-400"><%= @pending_subject_requests %></p>
      <p class="text-sm text-gray-400 mt-2">Demandes matières</p>
    </div>
    <div class="glass rounded-2xl p-6 text-center">
      <p class="text-4xl font-bold text-emerald-400"><%= @pending_resources %></p>
      <p class="text-sm text-gray-400 mt-2">Ressources en attente</p>
    </div>
    <div class="glass rounded-2xl p-6 text-center col-span-2 md:col-span-1 <%= @flagged_count > 0 ? 'ring-1 ring-orange-400/40' : '' %>">
      <p class="text-4xl font-bold <%= @flagged_count > 0 ? 'text-orange-400' : 'text-gray-500' %>"><%= @flagged_count %></p>
      <p class="text-sm text-gray-400 mt-2">En attente de modération</p>
    </div>
  </div>

  <div class="space-y-6">
    <div class="glass rounded-2xl p-6">
      <h2 class="text-2xl font-bold mb-4">Actions</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <%= link_to admin_posts_path, class: "p-4 bg-primary/20 hover:bg-primary/30 rounded-lg transition-colors text-primary font-medium" do %>
          <i class="fas fa-trash-alt mr-2"></i>Gérer les posts
        <% end %>
        <%= link_to admin_users_path, class: "p-4 bg-primary/20 hover:bg-primary/30 rounded-lg transition-colors text-primary font-medium" do %>
          <i class="fas fa-users mr-2"></i>Voir les utilisateurs
        <% end %>
        <%= link_to new_admin_message_path, class: "p-4 bg-primary/20 hover:bg-primary/30 rounded-lg transition-colors text-primary font-medium" do %>
          <i class="fas fa-envelope mr-2"></i>Envoyer un message
        <% end %>
        <%= link_to admin_subject_requests_path, class: "p-4 bg-yellow-500/20 hover:bg-yellow-500/30 rounded-lg transition-colors text-yellow-400 font-medium" do %>
          <i class="fas fa-inbox mr-2"></i>Demandes de matières
          <% if @pending_subject_requests > 0 %>
            <span class="ml-1 bg-yellow-400 text-black text-xs rounded-full px-2 py-0.5"><%= @pending_subject_requests %></span>
          <% end %>
        <% end %>
        <%= link_to new_admin_admin_path, class: "p-4 bg-yellow-500/20 hover:bg-yellow-500/30 rounded-lg transition-colors text-yellow-400 font-medium" do %>
          <i class="fas fa-crown mr-2"></i>Créer un administrateur
        <% end %>
        <%= link_to admin_resources_path, class: "p-4 bg-emerald-500/20 hover:bg-emerald-500/30 rounded-lg transition-colors text-emerald-400 font-medium" do %>
          <i class="fas fa-book-open mr-2"></i>Ressources à valider
          <% if @pending_resources > 0 %>
            <span class="ml-1 bg-emerald-500 text-white text-xs rounded-full px-2 py-0.5"><%= @pending_resources %></span>
          <% end %>
        <% end %>
        <%= link_to admin_event_candidates_path, class: "p-4 bg-accent/20 hover:bg-accent/30 rounded-lg transition-colors text-accent font-medium" do %>
          <i class="fas fa-calendar-alt mr-2"></i>Événements
          <% if @pending_event_candidates > 0 %>
            <span class="ml-1 bg-accent text-white text-xs rounded-full px-2 py-0.5"><%= @pending_event_candidates %></span>
          <% end %>
        <% end %>
        <%= link_to admin_moderation_path, class: "p-4 bg-orange-500/20 hover:bg-orange-500/30 rounded-lg transition-colors text-orange-400 font-medium" do %>
          <i class="fas fa-shield-alt mr-2"></i>Modération
          <% if @flagged_count > 0 %>
            <span class="ml-1 bg-orange-400 text-black text-xs rounded-full px-2 py-0.5"><%= @flagged_count %></span>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="glass rounded-2xl p-6">
      <h2 class="text-2xl font-bold mb-4">Posts récents</h2>
      <% if @recent_posts.any? %>
        <div class="space-y-3 max-h-96 overflow-y-auto">
          <% @recent_posts.each do |post| %>
            <div class="flex items-start justify-between p-3 bg-white/5 rounded-lg hover:bg-white/10 transition-colors">
              <div class="flex-1">
                <p class="font-semibold text-sm text-primary"><%= post.title %></p>
                <p class="text-xs text-gray-400 mt-1">Par <strong><%= post.user.display_name %></strong></p>
                <p class="text-xs text-gray-500 mt-1"><%= time_ago_in_words(post.created_at) %></p>
              </div>
              <%= button_to admin_post_path(post), method: :delete, data: { turbo_confirm: "Êtes-vous sûr ?" }, class: "px-3 py-1 text-red-400 text-xs rounded hover:bg-red-500/10 transition-colors" do %>
                <i class="fas fa-trash"></i>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-400 text-center py-4">Aucun post récent</p>
      <% end %>
    </div>
  </div>
</div>
