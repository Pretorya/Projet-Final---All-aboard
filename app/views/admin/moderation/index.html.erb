<% content_for :title, "Modération — Admin" %>

<div class="max-w-4xl mx-auto py-8 px-4">
  <div class="flex items-center gap-3 mb-8">
    <%= link_to admin_dashboard_path, class: "text-gray-400 hover:text-white transition-colors" do %>
      <i class="fas fa-arrow-left"></i>
    <% end %>
    <div>
      <h1 class="text-3xl font-bold">File de modération</h1>
      <p class="text-gray-400 text-sm mt-1">
        Contenu en attente —
        <span class="text-orange-400 font-semibold"><%= @flagged_posts.size + @flagged_comments.size %></span>
        élément<%= "s" if (@flagged_posts.size + @flagged_comments.size) != 1 %>
      </p>
    </div>
    <%= link_to admin_denylist_patterns_path, class: "ml-auto flex items-center gap-2 px-4 py-2 bg-white/5 hover:bg-white/10 text-gray-300 rounded-xl text-sm transition-colors" do %>
      <i class="fas fa-shield-alt"></i> Gérer la denylist
    <% end %>
  </div>

  <%# Posts flaggés %>
  <div class="glass rounded-2xl mb-6">
    <div class="p-5 border-b border-white/10 flex items-center gap-2">
      <i class="fas fa-file-alt text-orange-400"></i>
      <h2 class="font-semibold">Posts</h2>
      <span class="px-2 py-0.5 rounded-full text-xs bg-orange-400/15 text-orange-400 font-medium"><%= @flagged_posts.size %></span>
    </div>

    <% if @flagged_posts.any? %>
      <div class="divide-y divide-white/5">
        <% @flagged_posts.each do |post| %>
          <div class="p-5">
            <div class="flex items-start gap-3 mb-3">
              <img src="<%= post.user.profile_avatar %>" class="w-8 h-8 rounded-full flex-shrink-0">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-semibold text-sm"><%= post.user.display_name %></span>
                  <span class="text-xs text-gray-500"><%= time_ago_in_words(post.created_at) %></span>
                  <span class="px-2 py-0.5 rounded-full text-xs bg-orange-400/10 text-orange-400 border border-orange-400/20">En attente</span>
                </div>
                <p class="font-semibold text-white mb-1"><%= post.title %></p>
                <p class="text-sm text-gray-400 line-clamp-3"><%= post.body %></p>
              </div>
            </div>
            <div class="flex gap-3">
              <%= button_to approve_moderation_post_path(post), method: :post,
                  class: "flex items-center gap-2 px-4 py-2 bg-emerald-500/20 hover:bg-emerald-500/30 text-emerald-400 rounded-xl text-sm font-medium transition-colors" do %>
                <i class="fas fa-check"></i> Approuver
              <% end %>
              <%= button_to reject_moderation_post_path(post), method: :post,
                  data: { turbo_confirm: "Supprimer définitivement ce post ?" },
                  class: "flex items-center gap-2 px-4 py-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 rounded-xl text-sm font-medium transition-colors" do %>
                <i class="fas fa-trash"></i> Rejeter
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-8 text-center text-gray-500">
        <i class="fas fa-check-circle text-3xl mb-3 block text-emerald-400/50"></i>
        <p class="text-sm">Aucun post en attente de modération.</p>
      </div>
    <% end %>
  </div>

  <%# Commentaires flaggés %>
  <div class="glass rounded-2xl">
    <div class="p-5 border-b border-white/10 flex items-center gap-2">
      <i class="fas fa-comment text-orange-400"></i>
      <h2 class="font-semibold">Commentaires</h2>
      <span class="px-2 py-0.5 rounded-full text-xs bg-orange-400/15 text-orange-400 font-medium"><%= @flagged_comments.size %></span>
    </div>

    <% if @flagged_comments.any? %>
      <div class="divide-y divide-white/5">
        <% @flagged_comments.each do |comment| %>
          <div class="p-5">
            <div class="flex items-start gap-3 mb-3">
              <img src="<%= comment.user.profile_avatar %>" class="w-8 h-8 rounded-full flex-shrink-0">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-semibold text-sm"><%= comment.user.display_name %></span>
                  <span class="text-xs text-gray-500"><%= time_ago_in_words(comment.created_at) %></span>
                  <span class="px-2 py-0.5 rounded-full text-xs bg-orange-400/10 text-orange-400 border border-orange-400/20">En attente</span>
                </div>
                <p class="text-xs text-gray-500 mb-1">En réponse à : <span class="text-gray-400"><%= comment.post.title %></span></p>
                <p class="text-sm text-gray-300"><%= comment.body %></p>
              </div>
            </div>
            <div class="flex gap-3">
              <%= button_to approve_moderation_comment_path(comment), method: :post,
                  class: "flex items-center gap-2 px-4 py-2 bg-emerald-500/20 hover:bg-emerald-500/30 text-emerald-400 rounded-xl text-sm font-medium transition-colors" do %>
                <i class="fas fa-check"></i> Approuver
              <% end %>
              <%= button_to reject_moderation_comment_path(comment), method: :post,
                  data: { turbo_confirm: "Supprimer définitivement ce commentaire ?" },
                  class: "flex items-center gap-2 px-4 py-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 rounded-xl text-sm font-medium transition-colors" do %>
                <i class="fas fa-trash"></i> Rejeter
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-8 text-center text-gray-500">
        <i class="fas fa-check-circle text-3xl mb-3 block text-emerald-400/50"></i>
        <p class="text-sm">Aucun commentaire en attente de modération.</p>
      </div>
    <% end %>
  </div>
</div>
