<% content_for :title, "Admin - Envoyer un message" %>

<div class="max-w-2xl mx-auto py-8 px-4">
  <div class="mb-8">
    <h1 class="text-3xl font-bold mb-2">Envoyer un message</h1>
    <p class="text-gray-400">Envoyez un message privé à n'importe quel utilisateur</p>
    <%= link_to admin_dashboard_path, class: "text-primary hover:underline text-sm mt-4 inline-block" do %>
      <i class="fas fa-arrow-left mr-2"></i>Retour au tableau de bord
    <% end %>
  </div>

  <div class="glass rounded-2xl p-8">
    <%= form_with url: admin_send_message_to_user_path, method: :post, local: true do |f| %>
      <div class="mb-6">
        <%= f.label :user_id, "Destinataire *", class: "block text-sm font-medium mb-2 text-gray-300" %>
        <%= f.select :user_id, options_from_collection_for_select(@users, :id, :display_name), { prompt: "Sélectionner un utilisateur" }, class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary text-white" %>
      </div>

      <div class="mb-6">
        <%= f.label :message_body, "Message *", class: "block text-sm font-medium mb-2 text-gray-300" %>
        <%= f.text_area :message_body, rows: 6, placeholder: "Écrivez votre message...", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary resize-none text-white placeholder-gray-500" %>
      </div>

      <div class="flex gap-3">
        <%= f.submit "Envoyer le message", class: "px-6 py-3 rounded-xl bg-primary hover:bg-primary/80 text-white font-medium transition-colors" %>
        <%= link_to "Annuler", admin_dashboard_path, class: "px-6 py-3 rounded-xl border border-white/10 hover:bg-white/5 transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
