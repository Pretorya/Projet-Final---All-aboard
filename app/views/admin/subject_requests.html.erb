<% content_for :title, "Admin - Demandes de matières" %>

<div class="max-w-7xl mx-auto py-8 px-4">
  <div class="mb-8 flex justify-between items-start">
    <div>
      <h1 class="text-3xl font-bold mb-2">Demandes de matières</h1>
      <p class="text-gray-400"><%= @pending.count %> en attente · <%= @approved.count %> approuvée(s) · <%= @rejected.count %> rejetée(s)</p>
    </div>
    <%= link_to admin_dashboard_path, class: "text-primary hover:underline text-sm" do %>
      <i class="fas fa-arrow-left mr-2"></i>Retour au tableau de bord
    <% end %>
  </div>

  <%# Pending requests %>
  <div class="mb-10">
    <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
      <span class="w-3 h-3 rounded-full bg-yellow-400 inline-block"></span>
      En attente (<%= @pending.count %>)
    </h2>
    <% if @pending.any? %>
      <div class="space-y-3">
        <% @pending.each do |req| %>
          <div class="glass rounded-2xl p-5 flex items-start justify-between gap-4">
            <div class="flex-1">
              <p class="font-bold text-lg"><%= req.name %></p>
              <% if req.description.present? %>
                <p class="text-gray-400 text-sm mt-1"><%= req.description %></p>
              <% end %>
              <p class="text-xs text-gray-500 mt-2">
                Par <strong><%= req.user.display_name %></strong> · <%= time_ago_in_words(req.created_at) %>
              </p>
            </div>
            <div class="flex gap-2 shrink-0">
              <%= button_to admin_update_subject_request_path(req), method: :post, params: { status: "approved" }, data: { turbo_confirm: "Approuver cette demande ?" }, class: "px-4 py-2 bg-green-500/20 hover:bg-green-500/30 text-green-400 rounded-lg transition-colors text-sm font-medium" do %>
                <i class="fas fa-check mr-1"></i>Approuver
              <% end %>
              <%= button_to admin_update_subject_request_path(req), method: :post, params: { status: "rejected" }, data: { turbo_confirm: "Rejeter cette demande ?" }, class: "px-4 py-2 bg-red-500/20 hover:bg-red-500/30 text-red-400 rounded-lg transition-colors text-sm font-medium" do %>
                <i class="fas fa-times mr-1"></i>Rejeter
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="glass rounded-2xl p-6 text-center text-gray-400">
        <i class="fas fa-check-circle text-3xl text-green-400 mb-3"></i>
        <p>Aucune demande en attente.</p>
      </div>
    <% end %>
  </div>

  <%# Approved requests %>
  <% if @approved.any? %>
    <div class="mb-10">
      <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-green-400 inline-block"></span>
        Approuvées (<%= @approved.count %>)
      </h2>
      <div class="space-y-3">
        <% @approved.each do |req| %>
          <div class="glass rounded-2xl p-5 flex items-start justify-between gap-4 opacity-70">
            <div class="flex-1">
              <p class="font-bold"><%= req.name %></p>
              <% if req.description.present? %>
                <p class="text-gray-400 text-sm mt-1"><%= req.description %></p>
              <% end %>
              <p class="text-xs text-gray-500 mt-2">
                Par <strong><%= req.user.display_name %></strong> · <%= time_ago_in_words(req.created_at) %>
              </p>
            </div>
            <%= button_to admin_update_subject_request_path(req), method: :post, params: { status: "pending" }, class: "px-3 py-1 bg-white/10 hover:bg-white/20 text-gray-400 rounded-lg transition-colors text-xs shrink-0" do %>
              <i class="fas fa-undo mr-1"></i>Remettre en attente
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Rejected requests %>
  <% if @rejected.any? %>
    <div>
      <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-red-400 inline-block"></span>
        Rejetées (<%= @rejected.count %>)
      </h2>
      <div class="space-y-3">
        <% @rejected.each do |req| %>
          <div class="glass rounded-2xl p-5 flex items-start justify-between gap-4 opacity-60">
            <div class="flex-1">
              <p class="font-bold"><%= req.name %></p>
              <% if req.description.present? %>
                <p class="text-gray-400 text-sm mt-1"><%= req.description %></p>
              <% end %>
              <p class="text-xs text-gray-500 mt-2">
                Par <strong><%= req.user.display_name %></strong> · <%= time_ago_in_words(req.created_at) %>
              </p>
            </div>
            <%= button_to admin_update_subject_request_path(req), method: :post, params: { status: "pending" }, class: "px-3 py-1 bg-white/10 hover:bg-white/20 text-gray-400 rounded-lg transition-colors text-xs shrink-0" do %>
              <i class="fas fa-undo mr-1"></i>Remettre en attente
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
