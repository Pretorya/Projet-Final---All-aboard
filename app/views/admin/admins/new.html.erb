<% content_for :title, "Admin - Créer un administrateur" %>

<div class="max-w-2xl mx-auto py-8 px-4">
  <div class="mb-8">
    <h1 class="text-3xl font-bold mb-2">Créer un administrateur</h1>
    <p class="text-gray-400">Ajoutez un nouveau compte utilisateur avec les droits administrateur</p>
    <%= link_to admin_users_path, class: "text-primary hover:underline text-sm mt-4 inline-block" do %>
      <i class="fas fa-arrow-left mr-2"></i>Retour aux utilisateurs
    <% end %>
  </div>

  <div class="glass rounded-2xl p-8">
    <%= form_with model: @user, url: admin_admins_path, method: :post, local: true do |f| %>
      <% if @user.errors.any? %>
        <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 rounded-lg">
          <p class="text-red-400 font-semibold mb-2"><%= pluralize(@user.errors.count, "erreur") %> détectée(s) :</p>
          <ul class="list-disc list-inside text-red-400 text-sm">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-6">
        <%= f.label :full_name, "Nom complet *", class: "block text-sm font-medium mb-2 text-gray-300" %>
        <%= f.text_field :full_name, placeholder: "ex: Jean Dupont", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary text-white placeholder-gray-500" %>
      </div>

      <div class="mb-6">
        <%= f.label :email, "Adresse email *", class: "block text-sm font-medium mb-2 text-gray-300" %>
        <%= f.email_field :email, placeholder: "ex: admin@example.com", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary text-white placeholder-gray-500" %>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-6">
        <div>
          <%= f.label :password, "Mot de passe *", class: "block text-sm font-medium mb-2 text-gray-300" %>
          <%= f.password_field :password, placeholder: "••••••••", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary text-white placeholder-gray-500" %>
        </div>
        <div>
          <%= f.label :password_confirmation, "Confirmer le mot de passe *", class: "block text-sm font-medium mb-2 text-gray-300" %>
          <%= f.password_field :password_confirmation, placeholder: "••••••••", class: "w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary text-white placeholder-gray-500" %>
        </div>
      </div>

      <div class="p-4 bg-yellow-500/10 border border-yellow-500/30 rounded-lg mb-6">
        <p class="text-yellow-400 text-sm flex items-start gap-2">
          <i class="fas fa-crown mt-0.5"></i>
          <span>Ce compte sera créé avec les droits administrateur complets</span>
        </p>
      </div>

      <div class="flex gap-3">
        <%= f.submit "Créer l'administrateur", class: "px-6 py-3 rounded-xl bg-primary hover:bg-primary/80 text-white font-medium transition-colors" %>
        <%= link_to "Annuler", admin_users_path, class: "px-6 py-3 rounded-xl border border-white/10 hover:bg-white/5 transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
