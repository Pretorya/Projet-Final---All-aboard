<% content_for :title, "Admin - Gérer les posts" %>

<div class="max-w-7xl mx-auto py-8 px-4">
  <div class="mb-8">
    <h1 class="text-3xl font-bold mb-2">Gérer les posts</h1>
    <p class="text-gray-400">Total: <%= @posts.count %> posts</p>
    <%= link_to admin_dashboard_path, class: "text-primary hover:underline text-sm mt-4 inline-block" do %>
      <i class="fas fa-arrow-left mr-2"></i>Retour au tableau de bord
    <% end %>
  </div>

  <div class="space-y-4">
    <% if @posts.any? %>
      <% @posts.each do |post| %>
        <div class="glass rounded-2xl p-6 hover:bg-white/10 transition-colors">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <h3 class="text-xl font-bold mb-2"><%= post.title %></h3>
              <p class="text-gray-400 text-sm mb-3 line-clamp-2"><%= post.body %></p>
              <div class="flex items-center gap-4 text-xs text-gray-500">
                <span><strong>Auteur:</strong> <%= post.user.display_name %></span>
                <span><strong>Créé:</strong> <%= time_ago_in_words(post.created_at) %></span>
                <span><strong>Matière:</strong> <%= post.subject.name %></span>
                <span><strong>Commentaires:</strong> <%= post.comments.count %></span>
                <span><strong>J'aime:</strong> <%= post.likes.count %></span>
              </div>
            </div>
            <div class="flex gap-2 ml-4">
              <%= button_to admin_post_path(post), method: :delete, data: { turbo_confirm: "Êtes-vous sûr de vouloir supprimer ce post ?" }, class: "px-4 py-2 bg-red-500/20 hover:bg-red-500/30 text-red-400 rounded-lg transition-colors text-sm font-medium" do %>
                <i class="fas fa-trash mr-2"></i>Supprimer
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="glass rounded-2xl p-10 text-center text-gray-400">
        <i class="fas fa-inbox text-4xl text-primary mb-4"></i>
        <p>Aucun post trouvé.</p>
      </div>
    <% end %>
  </div>
</div>
