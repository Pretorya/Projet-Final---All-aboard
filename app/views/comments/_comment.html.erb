<div id="<%= dom_id(comment) %>" class="flex gap-3">
  <img src="<%= comment.user.profile_avatar %>" alt="<%= comment.user.display_name %>" class="w-9 h-9 rounded-full flex-shrink-0">
  <div class="flex-1">
    <div class="flex items-baseline justify-between gap-2">
      <p class="text-sm">
        <span class="font-semibold"><%= link_to comment.user.display_name, user_path(comment.user), class: "hover:text-primary transition-colors" %></span>
        <span class="text-gray-500 text-xs ml-2"><%= relative_time(comment.created_at) %></span>
      </p>
      <% if comment.user == current_user || current_user.admin? %>
        <%= button_to delete_comment_path(comment), method: :post,
                      class: "text-gray-600 hover:text-red-400 transition-colors text-xs",
                      data: { turbo_confirm: "Supprimer ce commentaire ?" },
                      form_class: "inline-block" do %>
          <i class="fas fa-trash"></i>
        <% end %>
      <% end %>
    </div>
    <p class="text-sm text-gray-300 mt-1"><%= comment.body %></p>
    <% if comment.code_snippet.present? %>
      <% lang = comment.code_language.presence || "plaintext" %>
      <div class="relative mt-2 rounded-xl overflow-hidden border border-white/8">
        <div class="flex items-center justify-between px-3 py-1.5 bg-black/40 border-b border-white/8">
          <span class="text-xs text-gray-500 font-mono"><%= lang == "plaintext" ? "texte" : lang %></span>
          <button type="button" onclick="navigator.clipboard.writeText(this.closest('.relative').querySelector('code').innerText)"
                  class="text-xs text-gray-500 hover:text-gray-300 transition-colors flex items-center gap-1">
            <i class="fas fa-copy"></i> Copier
          </button>
        </div>
        <pre class="!rounded-none !m-0 !border-0 text-sm"><code class="language-<%= lang %>"><%= comment.code_snippet %></code></pre>
      </div>
    <% end %>
  </div>
</div>
