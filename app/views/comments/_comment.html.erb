<%= turbo_frame_tag dom_id(comment) do %>
  <div class="flex gap-3">
    <img src="<%= comment.user.profile_avatar %>" alt="<%= comment.user.display_name %>" class="w-9 h-9 rounded-full flex-shrink-0">
    <div class="flex-1 min-w-0">
      <div class="flex items-center justify-between gap-2">
        <p class="text-sm">
          <span class="font-semibold"><%= link_to comment.user.display_name, user_path(comment.user), class: "hover:text-primary transition-colors", data: { turbo_frame: "_top" } %></span>
          <span class="text-gray-500 text-xs ml-2"><%= relative_time(comment.created_at) %></span>
        </p>
        <% if comment.user == current_user || current_user.admin? %>
          <div class="relative flex-shrink-0">
            <button type="button"
                    onclick="var m=this.nextElementSibling;m.classList.toggle('hidden');event.stopPropagation()"
                    class="w-7 h-7 flex items-center justify-center rounded-lg hover:bg-white/10 text-gray-400 hover:text-gray-200 transition-colors">
              <i class="fas fa-ellipsis-h text-sm"></i>
            </button>
            <div data-dropdown class="hidden absolute right-0 top-full mt-1 glass rounded-xl border border-white/10 py-1 z-50 min-w-[150px] shadow-xl">
              <% if comment.user == current_user %>
                <%= link_to edit_comment_path(comment), class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors" do %>
                  <i class="fas fa-edit text-xs w-3.5 text-center"></i> Modifier
                <% end %>
              <% end %>
              <%= button_to delete_comment_path(comment), method: :post,
                  class: "flex items-center gap-2.5 px-4 py-2 text-sm text-red-400 hover:bg-white/5 hover:text-red-300 transition-colors w-full text-left",
                  data: { turbo_confirm: "Supprimer ce commentaire ?" },
                  form_class: "w-full" do %>
                <i class="fas fa-trash text-xs w-3.5 text-center"></i> Supprimer
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
      <p class="text-sm text-gray-300 mt-1"><%= comment.body %></p>
      <% if comment.code_snippet.present? %>
        <% lang = comment.code_language.presence || "plaintext" %>
        <div class="relative mt-2 rounded-xl overflow-hidden border border-white/8">
          <div class="flex items-center justify-between px-3 py-1.5 bg-black/40 border-b border-white/8">
            <span class="text-xs text-gray-500 font-mono"><%= lang == "plaintext" ? "texte" : lang %></span>
            <button type="button" onclick="navigator.clipboard.writeText(this.closest('.relative').querySelector('code').innerText)"
                    class="text-xs text-gray-500 hover:text-gray-300 transition-colors flex items-center gap-1">
              <i class="fas fa-copy"></i> Copier
            </button>
          </div>
          <pre class="!rounded-none !m-0 !border-0 text-sm"><code class="language-<%= lang %>"><%= comment.code_snippet %></code></pre>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
