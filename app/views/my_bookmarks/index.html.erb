<% content_for :title, "Mes sauvegardes" %>

<div class="max-w-4xl mx-auto py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold mb-2">Mes sauvegardes</h1>
    <p class="text-gray-400"><%= @posts.size %> post<%= "s" if @posts.size > 1 %> sauvegardé<%= "s" if @posts.size > 1 %></p>
  </div>

  <div class="space-y-6">
    <% if @posts.any? %>
      <%= render @posts %>
    <% else %>
      <div class="glass rounded-2xl p-10 text-center text-gray-400">
        <i class="fas fa-bookmark text-4xl text-primary mb-4"></i>
        <p>Vous n'avez encore sauvegardé aucun post.</p>
        <p class="text-sm mt-2">Cliquez sur l'icône 🔖 d'un post pour le retrouver ici.</p>
        <%= link_to authenticated_root_path, class: "mt-4 inline-block px-6 py-2 bg-primary hover:bg-primary/80 text-white rounded-xl transition-colors text-sm font-medium" do %>
          Explorer le feed
        <% end %>
      </div>
    <% end %>
  </div>
</div>
