<% content_for :title, "Mes posts" %>

<div class="max-w-4xl mx-auto py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold mb-2">Mes posts</h1>
    <p class="text-gray-400">Voici la liste de tous vos posts</p>
  </div>

  <div class="space-y-6">
    <% if @posts.any? %>
      <%= render @posts %>
    <% else %>
      <div class="glass rounded-2xl p-10 text-center text-gray-400">
        <i class="fas fa-inbox text-4xl text-primary mb-4"></i>
        <p>Vous n'avez pas encore créé de post.</p>
        <button type="button" data-action="modal#open" class="mt-4 px-6 py-2 bg-primary hover:bg-primary/80 text-white rounded-xl transition-colors text-sm font-medium">
          Créer votre premier post
        </button>
      </div>
    <% end %>
  </div>
</div>
