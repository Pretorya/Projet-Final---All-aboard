<% content_for :title, "Nouvelle ressource" %>

<div class="max-w-2xl mx-auto py-8 px-4">
  <% back_path = current_user.admin? ? admin_dashboard_path : current_user.mentor? ? mentor_dashboard_path : resources_path %>
  <%= link_to back_path, class: "text-gray-400 hover:text-white transition-colors text-sm inline-flex items-center gap-2 mb-6" do %>
    <i class="fas fa-arrow-left"></i> Retour
  <% end %>

  <div class="glass rounded-2xl p-8">
    <h1 class="text-2xl font-bold mb-2">
      <i class="fas fa-plus-circle text-emerald-400 mr-2"></i>
      <%= current_user.admin? || current_user.mentor? ? "Publier une ressource" : "Proposer une ressource" %>
    </h1>
    <% unless current_user.admin? || current_user.mentor? %>
      <p class="text-sm text-gray-400 mb-6">Ta ressource sera soumise à validation avant d'être publiée.</p>
    <% else %>
      <div class="mb-6"></div>
    <% end %>
    <%= render "form", resource: @resource %>
  </div>
</div>
