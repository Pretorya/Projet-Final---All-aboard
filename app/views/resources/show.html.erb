<% content_for :title, @resource.title %>

<div class="max-w-3xl mx-auto py-8 px-4">
  <%= link_to resources_path, class: "text-gray-400 hover:text-white transition-colors text-sm inline-flex items-center gap-2 mb-6" do %>
    <i class="fas fa-arrow-left"></i> Toutes les ressources
  <% end %>

  <div class="glass rounded-2xl p-8">
    <div class="flex items-start justify-between gap-4 mb-6">
      <h1 class="text-2xl font-bold"><%= @resource.title %></h1>
      <% if @resource.subject %>
        <span class="shrink-0 px-3 py-1 bg-white/10 rounded-full text-sm"><%= @resource.subject.name %></span>
      <% end %>
    </div>

    <div class="flex items-center gap-3 mb-6 pb-6 border-b border-white/10">
      <img src="<%= @resource.user.profile_avatar %>" class="w-8 h-8 rounded-full">
      <div>
        <p class="text-sm font-medium">
          <%= @resource.user.display_name %>
          <span class="ml-2 text-xs text-emerald-400 font-semibold">
            <i class="fas fa-chalkboard-teacher mr-1"></i>Mentor
          </span>
        </p>
        <p class="text-xs text-gray-500">Publié <%= time_ago_in_words(@resource.created_at) %></p>
      </div>
    </div>

    <div class="prose prose-invert max-w-none text-gray-200 leading-relaxed whitespace-pre-wrap">
      <%= @resource.body %>
    </div>
  </div>
</div>
