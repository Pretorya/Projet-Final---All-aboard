<% content_for :title, "Ressources" %>

<div class="max-w-4xl mx-auto py-8 px-4">
  <div class="flex items-start justify-between gap-4 mb-6">
    <div>
      <h1 class="text-3xl font-bold mb-2">
        <i class="fas fa-book-open text-emerald-400 mr-3"></i>Ressources
      </h1>
      <p class="text-gray-400">Guides et ressources pédagogiques partagés par la communauté AllAboard.</p>
    </div>
    <%= link_to new_resource_path, class: "flex-shrink-0 flex items-center gap-2 px-4 py-2 bg-emerald-500 hover:bg-emerald-400 text-white rounded-xl font-medium transition-colors text-sm" do %>
      <i class="fas fa-plus"></i>
      <% if current_user.admin? || current_user.mentor? %>
        Publier une ressource
      <% else %>
        Proposer une ressource
      <% end %>
    <% end %>
  </div>

  <%# Barre de recherche %>
  <%= form_with url: resources_path, method: :get, data: { turbo: false }, class: "mb-6" do |f| %>
    <div class="relative">
      <i class="fas fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-sm pointer-events-none"></i>
      <%= f.search_field :q,
          value: @search_query,
          placeholder: "Rechercher par titre, contenu, matière ou sous-tag…",
          class: "w-full bg-white/5 border border-white/10 rounded-xl pl-10 pr-28 py-3 text-sm focus:outline-none focus:border-emerald-500 transition-colors placeholder-gray-500",
          autocomplete: "off" %>
      <div class="absolute right-2 top-1/2 -translate-y-1/2 flex items-center gap-2">
        <% if @search_query.present? %>
          <%= link_to resources_path, class: "text-xs text-gray-500 hover:text-gray-300 transition-colors px-2 py-1" do %>
            <i class="fas fa-times"></i>
          <% end %>
        <% end %>
        <button type="submit" class="px-3 py-1.5 bg-emerald-500/20 hover:bg-emerald-500/30 text-emerald-400 rounded-lg text-xs font-medium transition-colors">
          Rechercher
        </button>
      </div>
    </div>
    <% if @search_query.present? %>
      <p class="mt-2 text-xs text-gray-400">
        <span class="text-emerald-400 font-medium"><%= @resources.size %></span>
        résultat<%= "s" if @resources.size != 1 %> pour
        <span class="text-white/70 italic">"<%= @search_query %>"</span>
      </p>
    <% end %>
  <% end %>

  <% if @resources.any? %>
    <div class="space-y-4">
      <% @resources.each do |resource| %>
        <div class="glass rounded-2xl p-6 hover:bg-white/5 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <h2 class="text-lg font-semibold mb-1">
                <%= link_to resource.title, resource_path(resource), class: "hover:text-emerald-400 transition-colors" %>
              </h2>
              <p class="text-gray-400 text-sm line-clamp-2"><%= resource.body.truncate(180) %></p>
              <div class="flex flex-wrap items-center gap-2 mt-3">
                <span class="flex items-center gap-1 text-xs">
                  <img src="<%= resource.user.profile_avatar %>" class="w-4 h-4 rounded-full">
                  <span class="text-emerald-400 font-medium"><%= resource.user.display_name %></span>
                  <i class="fas fa-chalkboard-teacher text-emerald-400/70 ml-0.5"></i>
                </span>
                <% if resource.subject %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium border"
                        style="color:<%= resource.subject.accent_color %>;border-color:<%= resource.subject.accent_color %>33;background-color:<%= resource.subject.accent_color %>18;">
                    <i class="fas <%= resource.subject.icon %> text-[10px]"></i>
                    <%= resource.subject.name %>
                  </span>
                <% end %>
                <% resource.tags.each do |tag| %>
                  <span class="px-2 py-0.5 rounded-full text-xs text-gray-400 bg-white/5 border border-white/8">#<%= tag.name %></span>
                <% end %>
                <span class="text-xs text-gray-500 ml-auto"><%= time_ago_in_words(resource.created_at) %></span>
              </div>
            </div>
            <%= link_to resource_path(resource), class: "text-gray-400 hover:text-emerald-400 transition-colors shrink-0" do %>
              <i class="fas fa-arrow-right"></i>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="glass rounded-2xl p-12 text-center text-gray-400">
      <i class="fas fa-book-open text-4xl mb-4 block text-emerald-400/50"></i>
      <% if @search_query.present? %>
        <p class="font-medium mb-2">Aucune ressource ne correspond à "<%= @search_query %>".</p>
        <p class="text-sm"><%= link_to "Effacer la recherche", resources_path, class: "text-emerald-400 hover:underline" %></p>
      <% else %>
        <p class="font-medium mb-2">Aucune ressource disponible pour le moment.</p>
        <p class="text-sm">Sois le premier à proposer une ressource à la communauté.</p>
      <% end %>
    </div>
  <% end %>
</div>
