<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nouveau message — AllAboard</title>
</head>
<body style="margin:0;padding:0;background-color:#0f172a;font-family:'Inter',Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#0f172a;padding:40px 20px;">
    <tr>
      <td align="center">
        <table width="560" cellpadding="0" cellspacing="0" style="background-color:#1e293b;border-radius:24px;overflow:hidden;border:1px solid rgba(255,255,255,0.08);">

          <%# Header %>
          <tr>
            <td style="background:linear-gradient(135deg,#6366f1,#ec4899);padding:36px 40px;text-align:center;">
              <table cellpadding="0" cellspacing="0" align="center">
                <tr>
                  <td style="background:rgba(255,255,255,0.15);border-radius:14px;padding:12px 16px;">
                    <span style="font-size:24px;">🎓</span>
                    <span style="color:#ffffff;font-size:22px;font-weight:800;margin-left:8px;vertical-align:middle;">AllAboard</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <%# Body %>
          <tr>
            <td style="padding:40px 40px 32px;">
              <p style="margin:0 0 6px;color:#94a3b8;font-size:14px;text-transform:uppercase;letter-spacing:0.08em;">Message privé</p>
              <h1 style="margin:0 0 16px;color:#ffffff;font-size:22px;font-weight:700;">
                💬 <%= @sender.display_name %> t'a envoyé un message
              </h1>

              <div style="background:rgba(99,102,241,0.08);border:1px solid rgba(99,102,241,0.25);border-radius:16px;padding:20px 24px;margin-bottom:28px;">
                <div style="display:flex;align-items:center;margin-bottom:12px;">
                  <div style="width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#6366f1,#8b5cf6);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#fff;flex-shrink:0;">
                    <%= @sender.initials %>
                  </div>
                  <span style="margin-left:10px;color:#e2e8f0;font-weight:600;font-size:15px;"><%= @sender.display_name %></span>
                </div>
                <% if @message.body.present? %>
                  <p style="margin:0;color:#cbd5e1;font-size:15px;line-height:1.6;"><%= @message.body %></p>
                <% else %>
                  <p style="margin:0;color:#64748b;font-size:14px;font-style:italic;">[Pièce jointe]</p>
                <% end %>
              </div>

              <table cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td align="center" style="padding:0 0 28px;">
                    <%= link_to conversation_url(@conversation),
                                style: "display:inline-block;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#ffffff;text-decoration:none;font-weight:700;font-size:15px;padding:14px 36px;border-radius:14px;" do %>
                      Voir la conversation
                    <% end %>
                  </td>
                </tr>
              </table>

              <p style="margin:0;color:#475569;font-size:13px;line-height:1.5;">
                Tu reçois cet e-mail car tu as activé les notifications de messages privés.
                Tu peux désactiver cette option dans <a href="<%= edit_user_registration_url %>" style="color:#6366f1;text-decoration:none;">les paramètres de ton compte</a>.
              </p>
            </td>
          </tr>

          <%# Footer %>
          <tr>
            <td style="padding:20px 40px 32px;border-top:1px solid rgba(255,255,255,0.06);">
              <p style="margin:0;color:#334155;font-size:12px;text-align:center;">
                © <%= Date.current.year %> AllAboard — La plateforme d'entraide étudiante<br>
                Cet e-mail a été envoyé à <strong style="color:#475569;"><%= @recipient.email %></strong>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
